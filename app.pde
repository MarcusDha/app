color olive = #ECF39E;
color lightGreen = #90A955;
color green = #4F772D;
color darkGreen = #31572c;

color selected;

void setup() {
  size(600,600);
  
}

void draw() {
  background(olive);
  stroke(0);
  strokeWeight(3);
  
  fill(lightGreen);
  circle(100,500,100);
  
  fill(green);
  circle(300,500,100);
  
  fill(darkGreen);
  circle(500,500,100);
  
  fill(selected);
  rect(100,100,400,300);
}

